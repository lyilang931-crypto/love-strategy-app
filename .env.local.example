# Gemini API Key
# Google AI Studio (https://aistudio.google.com/) からAPIキーを取得してください
GEMINI_API_KEY=your_gemini_api_key_here

# Coconala コーチングページURL
NEXT_PUBLIC_COCONALA_URL=https://coconala.com/your-service-url

# Web Push VAPID Keys
# 以下のコマンドで生成できます: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNR6Hx5hZH2CmlsWPzlOeF2usAhHAed0af1kCT_Vt65hFklU4dnR9-XNau_0IBNfrBfqtslltGtP55vWFRvhOg4
VAPID_PRIVATE_KEY=IMgl5R_wuPbbluUP_rVKJA0D7DnAm8GZf9sbA3IeqZ4
VAPID_EMAIL=your-email@example.com

# Vercel Cron 保護用シークレット（任意）
CRON_SECRET=your-random-secret-here

# Supabase（任意 - ニックネーム保存・プッシュ通知パーソナライズに使用）
# Supabase ダッシュボード → Settings → API から取得
# https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# LINE Messaging API（デイリーリマインダー送信に使用）
# LINE Developers コンソール → チャネル → Messaging API設定 から取得
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token-here
LINE_CHANNEL_SECRET=your-line-channel-secret-here

# アプリのURL（LINEメッセージ内リンクに使用）
# 例: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
